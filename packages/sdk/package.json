{
  "name": "@slik-pay/sdk",
  "version": "0.1.1",
  "description": "SLIK SDK - 6-code payments on Solana (inspired by BLIK)",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.mjs",
      "require": "./dist/react/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/konradbachowski/slik.git",
    "directory": "packages/sdk"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "@solana/web3.js": "^1.90.0",
    "@solana/spl-token": "^0.4.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "@solana/spl-token": {
      "optional": true
    }
  },
  "devDependencies": {
    "@solana/web3.js": "^1.98.4",
    "@solana/spl-token": "^0.4.14",
    "react": "^19.2.4",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "@types/react": "^19.0.0"
  },
  "files": [
    "dist"
  ],
  "license": "MIT"
}
